# Copy to repo root as `.env` (gitignored). Never commit real values.

# --- LLM providers (pick what you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Property / parcel / enrichment (examples; enable per integration) ---
ATTOM_API_KEY=
REGRID_API_KEY=
MAPBOX_ACCESS_TOKEN=

# --- Optional: geocode / maps ---
GOOGLE_MAPS_API_KEY=

# --- App ---
APPRAISAL_AI_ENV=development
APPRAISAL_AI_LOG_LEVEL=INFO
